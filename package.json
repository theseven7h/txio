{
  "name": "txio-monorepo",
  "private": true,
  "scripts": {
    "dev:backend": "cd backend/api && cargo run",
    "dev:frontend": "cd frontend && npm run dev",
    "dev:desktop": "cd desktop && npm start",
    "build": "npm run build --workspaces && node scripts/copy-frontend-out.mjs",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "workspaces": [
    "frontend",
    "desktop"
  ]
}
