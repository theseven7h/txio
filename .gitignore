# Build Artifacts
target/
dist/
build/
node_modules/
.next/
out/
# Bun is not part of the toolchain (npm workspaces + package-lock.json are);
# ignore its lockfile so it can't be swept into a commit by accident.
bun.lock

# Environment
.env
.env.local
.env.*.local

# IDEs
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Rust
**/*.rs.bk
# Cargo.lock is intentionally committed (the workspace ships binaries)
